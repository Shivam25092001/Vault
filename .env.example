# Copy to .env and fill in from Supabase → Project Settings → API Keys.
# Both values are public-safe: they ship in the client bundle by design.
# The write gate is the storage INSERT policy, not the key.
# NEVER put the service_role / secret key in this file.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon or publishable key>

